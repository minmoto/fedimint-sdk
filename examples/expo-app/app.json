{
  "expo": {
    "name": "Fedimint Expo App",
    "slug": "expo-app-example",
    "version": "1.0.0",
    "scheme": "fedimint-expo-app",
    "platforms": ["ios", "android"],
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "bundleIdentifier": "org.fedimint.expoapp",
      "supportsTablet": true
    },
    "android": {
      "package": "org.fedimint.expoapp",
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      }
    },
    "plugins": ["expo-router"],
    "extra": {
      "router": {}
    }
  }
}
