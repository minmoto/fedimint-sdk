{
  "name": "@minmoto/react-native-bindings",
  "version": "0.1.0",
  "description": "Fedimint Client SDK for React-Native",
  "source": "./src/index.tsx",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/module/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/module/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./app.plugin.js": "./app.plugin.js",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "scripts",
    "cpp",
    "plugin",
    "plugin/build",
    "patches",
    "app.plugin.js",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!android/src/main/jniLibs",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*",
    "!*.xcframework"
  ],
  "scripts": {
    "ubrn:ios": "ubrn build ios --and-generate && patch -p0 --forward < patches/add_ios_frameworks.patch",
    "plugin:build": "EXPO_NONINTERACTIVE=true expo-module build plugin",
    "plugin:clean": "expo-module clean plugin",
    "plugin:watch": "expo-module build plugin",
    "ubrn:android": "ubrn build android --and-generate && patch -p0 --forward < patches/rn083_callinvoker.patch || true",
    "ubrn:ios:release": "ubrn build ios --and-generate --release && patch -p0 --forward < patches/add_ios_frameworks.patch && patch -p0 --forward < patches/rn083_callinvoker.patch || true",
    "ubrn:android:release": "ubrn build android --and-generate --release && patch -p0 --forward < patches/rn083_callinvoker.patch || true",
    "ubrn:checkout": "ubrn checkout",
    "ubrn:clean": "rm -rfv cpp/ android/CMakeLists.txt android/src/main/java android/*.cpp ios/ src/Native* src/index.*ts* src/generated/",
    "clean:deep": "pnpm clean && rm -rfv cpp/ android/CMakeLists.txt android/src/main/java android/*.cpp ios/ src/Native* src/index.*ts* src/generated/",
    "clean": "rm -rfv android/build example/android/build example/android/app/build example/ios/build lib plugin/build",
    "build": "bob build && pnpm plugin:build",
    "typecheck": "tsc",
    "postinstall": "node scripts/download-binaries.js",
    "prepare": "pnpm plugin:build"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "fedimint",
    "bitcoin",
    "lightning",
    "wallet"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minmoto/fedimint-sdk.git"
  },
  "author": "Fedimint Developers <reach.oms2004@gmail.com> (https://github.com/fedimint)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/minmoto/fedimint-sdk/issues"
  },
  "homepage": "https://github.com/minmoto/fedimint-sdk#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@expo/config-plugins": "^54.0.4",
    "@react-native-community/cli": "20.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": ">=19.2.14",
    "del-cli": "^5.1.0",
    "expo-module-scripts": "^5.0.8",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "react": ">=19.2.4",
    "react-native": "0.83.1",
    "react-native-builder-bob": "^0.40.18",
    "typescript": "^5.9.3"
  },
  "resolutions": {
    "@types/react": ">=19.2.14"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.78.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "codegen",
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "ReactNativeBindingsSpec",
    "type": "all",
    "jsSrcsDir": "src",
    "outputDir": {
      "android": "android/generated",
      "ios": "ios/generated"
    },
    "android": {
      "javaPackageName": "com.fedimint.reactnative"
    },
    "includesGeneratedCode": true
  },
  "create-react-native-library": {
    "type": "module-new",
    "languages": "cpp",
    "version": "0.41.2"
  },
  "dependencies": {
    "uniffi-bindgen-react-native": "0.29.3-1"
  }
}
