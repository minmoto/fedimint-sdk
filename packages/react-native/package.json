{
  "name": "@minmoto/react-native",
  "description": "React Native SDKfor the Fedimint client",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/minmoto/fedimint-sdk.git",
    "directory": "packages/react-native"
  },
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/commonjs/index.d.ts",
  "react-native": "./src/index.ts",
  "source": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/commonjs/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./app.plugin.js": "./app.plugin.js",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "app.plugin.js"
  ],
  "scripts": {
    "build": "bob build",
    "clean": "rm -rf lib tsconfig.tsbuildinfo",
    "clean:deep": "pnpm run clean && rm -rf node_modules",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fedimint/core": "workspace:*",
    "@minmoto/react-native-bindings": "workspace:*",
    "@fedimint/types": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.78.0"
  },
  "devDependencies": {
    "@expo/config-plugins": "^54.0.4",
    "@types/node": "^22.19.11",
    "expo-module-scripts": "^5.0.8",
    "react-native-builder-bob": "^0.40.18",
    "typescript": "^5.9.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  }
}
